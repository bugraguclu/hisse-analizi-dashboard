APP_ENV=development
DATABASE_URL=postgresql+asyncpg://hisse:hisse@localhost:5432/hisse_analizi
DATABASE_URL_SYNC=postgresql://hisse:hisse@localhost:5432/hisse_analizi
TZ=Europe/Istanbul
DEFAULT_POLL_INTERVAL_SECONDS=30
USER_AGENT=HisseAnalizi/1.0
LOG_LEVEL=INFO

# Admin API key — required in production, optional in dev (all admin calls bypass auth in dev if unset)
ADMIN_API_KEY=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_ADMIN=20/minute
RATE_LIMIT_EXPENSIVE=30/minute

# Worker settings
WORKER_MAX_CONCURRENCY=5
WORKER_SINGLE_REPLICA=true

# SMTP (optional — dry-run if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
ENABLE_REAL_EMAIL=false
