APP_ENV=development
DATABASE_URL=postgresql+asyncpg://aefes:aefes@localhost:5432/aefes_listener
DATABASE_URL_SYNC=postgresql://aefes:aefes@localhost:5432/aefes_listener
TZ=Europe/Istanbul
DEFAULT_POLL_INTERVAL_SECONDS=30
USER_AGENT=AEFESListener/1.0
LOG_LEVEL=INFO

# SMTP (opsiyonel - yoksa dry-run)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
ENABLE_REAL_EMAIL=false
