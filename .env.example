APP_ENV=development
DATABASE_URL=postgresql+asyncpg://hisse:hisse@localhost:5432/hisse_analizi
DATABASE_URL_SYNC=postgresql://hisse:hisse@localhost:5432/hisse_analizi
TZ=Europe/Istanbul
DEFAULT_POLL_INTERVAL_SECONDS=30
USER_AGENT=HisseAnalizi/1.0
LOG_LEVEL=INFO

# SMTP (opsiyonel - yoksa dry-run)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
ENABLE_REAL_EMAIL=false
